# This .gitignore is optimized based on GitHub's official templates for general projects,
# including common ignores for macOS, Windows, Linux, and development tools.
# For project-specific needs (e.g., if this is a web/graphics project), add more entries as needed.

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*

# Node.js (if applicable for web/graphics tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Python (if applicable)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Editor directories and files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini

# Build outputs
build/
dist/
out/

# Temporary files
*.tmp
*.temp

# Backup files
*.bak
*.backup

# Swap files
*.swp
*.swo

# Lock files
package-lock.json
yarn.lock
# Uncomment if you want to ignore lock files, but generally keep them for consistency

# Secrets and sensitive data
secrets/
*.key
*.pem
*.crt
*.p12
*.pfx

# Database files
*.db
*.sqlite
*.sqlite3

# Media files (common for thumbnail templates; adjust as needed)
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mkv
*.webm
*.m4v
*.3gp
*.mpg
*.mpeg
*.gif
*.jpg
*.jpeg
*.png
*.bmp
*.tiff
*.tif
*.svg
*.ico
*.webp
*.heic
*.raw
*.psd
*.ai
*.eps
*.pdf
# Uncomment specific media types if you want to track them

# Archives
*.zip
*.rar
*.7z
*.tar.gz
*.tar.bz2
*.tar.xz

# Miscellaneous
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.o
*.obj